{
    "name": "utp/bolsa-trabajo",
    "description": "Plataforma de bolsa de trabajo y seguimiento de egresados",
    "license": "MPL-2.0",
    "type": "project",
    "require": {
        "php": ">=7.4",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "phpmailer/phpmailer": "^7.1"
    },
    "config": {
        "platform-check": true,
        "platform": {
            "php": "7.4.0"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    }
}
