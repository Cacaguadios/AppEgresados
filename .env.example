APP_NAME=Bolsa de Trabajo UTP
APP_URL=http://localhost/AppEgresados
APP_BASE_PATH=/AppEgresados
APP_ENV=development
APP_DEBUG=true
APP_KEY=generate-a-random-value-with-at-least-32-characters

APP_DB_HOST=127.0.0.1
APP_DB_PORT=3306
APP_DB_NAME=bolsa_trabajo_utp
APP_DB_USER=appegresados_local
APP_DB_PASS=change-this-local-password

MAIL_DRIVER=log
MAIL_HOST=
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USER=
MAIL_PASS=
MAIL_FROM=no-reply@example.test
MAIL_FROM_NAME=Bolsa de Trabajo UTP
MAIL_ALLOW_SELF_SIGNED=false

SESSION_TIMEOUT=3600
SESSION_ABSOLUTE_TIMEOUT=43200
CSRF_TOKEN_EXPIRY=3600
PASSWORD_MIN_LENGTH=8
MAX_FILE_UPLOAD_SIZE=5242880
